{
  "realm": "petorg-dev",
  "enabled": true,
  "displayName": "PetOrg Dev",
  "roles": {
    "realm": [
      {
        "name": "Donor",
        "description": "Donor role for donor-facing capabilities."
      },
      {
        "name": "Staff",
        "description": "Staff role for administrative capabilities."
      }
    ]
  },
  "clients": [
    {
      "clientId": "petorg-api",
      "name": "PetOrg API",
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "petorg-api-dev-secret",
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "protocolMappers": [
        {
          "name": "audience-petorg-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "petorg-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "petorg-frontend",
      "name": "PetOrg Frontend",
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "offline_access"
      ]
    }
  ],
  "users": [
    {
      "username": "staff.dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Staff",
      "lastName": "Dev",
      "email": "staff.dev@petorg.local",
      "credentials": [
        {
          "type": "password",
          "value": "Staff123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "Staff"
      ]
    },
    {
      "username": "donor.dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Donor",
      "lastName": "Dev",
      "email": "donor.dev@petorg.local",
      "credentials": [
        {
          "type": "password",
          "value": "Donor123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "Donor"
      ]
    }
  ]
}
