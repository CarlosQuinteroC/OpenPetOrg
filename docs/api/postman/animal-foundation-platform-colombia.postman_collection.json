{
  "info": {
    "_postman_id": "d9c86f65-3d0a-4a4d-9b08-0f2f6a2a8b19",
    "name": "PetOrg Local Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Get Token (staff.dev)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "auth": {
          "type": "noauth"
        },
        "url": {
          "raw": "{{keycloak_base}}/realms/{{realm}}/protocol/openid-connect/token",
          "host": ["{{keycloak_base}}"],
          "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "client_id", "value": "{{frontend_client_id}}", "type": "text" },
            { "key": "grant_type", "value": "password", "type": "text" },
            { "key": "username", "value": "{{username}}", "type": "text" },
            { "key": "password", "value": "{{password}}", "type": "text" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Has access_token', function () {",
              "  pm.expect(json.access_token).to.be.a('string');",
              "});",
              "pm.environment.set('access_token', json.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Get Current User (/api/me)",
      "request": {
        "method": "GET",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{api_base}}/api/me",
          "host": ["{{api_base}}"],
          "path": ["api", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "keycloak_base", "value": "http://localhost:8080" },
    { "key": "realm", "value": "petorg-dev" },
    { "key": "frontend_client_id", "value": "petorg-frontend" },
    { "key": "username", "value": "staff.dev" },
    { "key": "password", "value": "Staff123!" },
    { "key": "api_base", "value": "http://localhost:5299" },
    { "key": "access_token", "value": "" }
  ]
}