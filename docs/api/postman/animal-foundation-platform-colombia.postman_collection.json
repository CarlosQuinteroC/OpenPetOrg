{
  "info": {
    "_postman_id": "f4ba9c4a-0cc5-46be-9d6a-5f1b66c70ee3",
    "name": "PetOrg Animal Foundation Platform Colombia",
    "description": "Backend API verification collection for PR3 (tests + documentation gate).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get current user",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "me"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Donations",
      "item": [
        {
          "name": "Create donation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"donorId\": \"{{donor_id}}\",\n  \"amount\": 120000,\n  \"currency\": \"COP\",\n  \"channel\": \"online\",\n  \"reference\": \"gw-transaction-001\",\n  \"occurredAt\": \"{{$isoTimestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/donations",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "donations"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Donation created', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.environment.set('donation_id', json.donationId);"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Reconciliation",
      "item": [
        {
          "name": "Confirm unique donor match",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matchedDonorId\": \"{{donor_id}}\",\n  \"evidenceNote\": \"Matched against bank transfer reference\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/reconciliation/{{donation_id}}/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reconciliation",
                "{{donation_id}}",
                "confirm"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Mark ambiguous match",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"selectedDonorId\": \"{{donor_id}}\",\n  \"resolutionNote\": \"Manual review required due to duplicate donor attributes\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/reconciliation/{{donation_id}}/ambiguous",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reconciliation",
                "{{donation_id}}",
                "ambiguous"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Recurring",
      "item": [
        {
          "name": "Enroll recurring donor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"donorId\": \"{{donor_id}}\",\n  \"amount\": 60000,\n  \"currency\": \"COP\",\n  \"startedOn\": \"2026-06-01\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/recurring",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "recurring"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('recurring_id', json.recurringDonationId);"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Consent",
      "item": [
        {
          "name": "Append public recognition consent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"granted\": true,\n  \"effectiveAt\": \"{{$isoTimestamp}}\",\n  \"actorId\": \"staff-user-01\",\n  \"note\": \"Donor accepted disclosure\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/donors/{{donor_id}}/consent/public-recognition",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "donors",
                "{{donor_id}}",
                "consent",
                "public-recognition"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get public recognition visibility",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/donors/{{donor_id}}/public-recognition/visibility?at={{visibility_at}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "donors",
                "{{donor_id}}",
                "public-recognition",
                "visibility"
              ],
              "query": [
                {
                  "key": "at",
                  "value": "{{visibility_at}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Receipts",
      "item": [
        {
          "name": "Issue final receipt",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiptNumber\": \"REC-2026-010\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/receipts/{{donation_id}}/issue-final",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "receipts",
                "{{donation_id}}",
                "issue-final"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
